generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  createdTasks      Task[]            @relation("TaskCreator")
  assignedTasks     Task[]            @relation("TaskAssignee")
  createdNotes      Note[]
  habits            Habit[]
  goals             Goal[]

  @@map("users")
}

model Workspace {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        String        @default("personal") // personal | family | friends | community
  emoji       String?       @default("🏠")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  ownerId  String
  owner    User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  WorkspaceMember[]
  tasks    Task[]
  notes    Note[]
  goals    Goal[]
  habits   Habit[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  status      String   @default("accepted") // accepted | pending
  joinedAt    DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending") // pending | ongoing | done
  priority    String    @default("medium")  // low | medium | high
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation("TaskCreator", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?    @relation("TaskAssignee", fields: [assignedToId], references: [id])

  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@map("notes")
}

model Goal {
  id            String    @id @default(cuid())
  title         String
  description   String?
  category      String?
  icon          String?   @default("🎯")
  color         String?   @default("#6470f3")
  targetValue   Float
  currentValue  Float     @default(0)
  unit          String    // e.g. "KG", "Books", "৳", "Hours", "%", custom
  status        String    @default("active") // active | completed | paused | cancelled
  startDate     String?   // YYYY-MM-DD
  targetDate    String?   // YYYY-MM-DD
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workspaceId   String
  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressHistory GoalProgressHistory[]

  @@map("goals")
}

model GoalProgressHistory {
  id             String   @id @default(cuid())
  previousValue  Float
  updatedValue   Float
  note           String?
  createdAt      DateTime @default(now())

  goalId         String
  goal           Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_progress_history")
}

model Habit {
  id          String   @id @default(cuid())
  title       String
  description String?
  emoji       String?  @default("✨")
  color       String?  @default("#6470f3")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]

  @@map("habits")
}

model HabitCompletion {
  id          String   @id @default(cuid())
  completedAt DateTime @default(now())
  date        String   // YYYY-MM-DD format for easy querying

  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@map("habit_completions")
}
